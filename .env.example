# Copy this file to .env (optional — Ollama works without it)

# --- Ollama (default, local) ---
# Install from https://ollama.com, then: ollama pull llama3
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434

# --- OpenAI (optional, cloud) ---
# OPENAI_API_KEY=sk-your-key-here
# LLM_PROVIDER=openai

# --- Embeddings (optional) ---
# EMBEDDING_PROVIDER=ollama  # for local nomic-embed-text
